{
  "name": "slack-action",
  "description": "GitHub Action to send Slack notifications about your pipelines progress.",
  "version": "1.2.0",
  "author": {
    "name": "Victor Popkov",
    "email": "victor@popkov.me"
  },
  "dependencies": {
    "@actions/core": "^2.0.3",
    "@actions/github": "^8.0.1",
    "@slack/bolt": "^4.7.3",
    "sprintf-js": "^1.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/sprintf-js": "^1.1.4",
    "@vercel/ncc": "^0.44.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "lodash": "^4.18.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "yarn-audit-fix": "^10.1.1",
    "yarn-deduplicate": "^6.0.2"
  },
  "homepage": "https://github.com/codedsolar/slack-action#readme",
  "keywords": [
    "github-action",
    "slack",
    "slack-action"
  ],
  "license": "MIT",
  "main": "lib/index.js",
  "repository": {
    "type": "git",
    "url": "github:codedsolar/slack-action"
  },
  "scripts": {
    "audit:fix": "yarn-audit-fix",
    "build": "tsc && ncc build",
    "ci:eslint": "eslint --format='./.github/eslint-output.js' .",
    "ci:jest": "jest --ci --coverage=false --reporters='./.github/jest-output.js' --silent",
    "ci:prettier": "node ./.github/prettier-output.js",
    "clean": "rm -rf ./coverage/ ./lib/ && find ./src -name '*.js' -type f -delete",
    "deduplicate": "yarn-deduplicate && yarn install --ignore-scripts",
    "lint": "npm-run-all --continue-on-error lint:*",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check .",
    "prepare": "npm run build",
    "test": "npm-run-all --continue-on-error test:*",
    "test:jest": "jest --coverage"
  },
  "types": "src/types/index.d.ts"
}
