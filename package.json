{
  "name": "slack-action",
  "version": "1.2.0",
  "description": "GitHub Action to send Slack notifications about your pipelines progress.",
  "keywords": [
    "github-action",
    "slack",
    "slack-action"
  ],
  "homepage": "https://github.com/codedsolar/slack-action#readme",
  "repository": {
    "type": "git",
    "url": "github:codedsolar/slack-action"
  },
  "license": "MIT",
  "author": {
    "name": "Victor Popkov",
    "email": "victor@popkov.me"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "audit:fix": "pnpm audit --fix",
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --target=node24 --minify --banner:js='import{createRequire as __cr}from\"node:module\";const require=__cr(import.meta.url);'",
    "ci:eslint": "eslint --format='./.github/eslint-output.js' .",
    "ci:jest": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --ci --coverage=false --reporters='./.github/jest-output.js' --silent",
    "ci:prettier": "node ./.github/prettier-output.js",
    "ci:sort-package-json": "node ./.github/sort-package-json-output.js",
    "clean": "rm -rf ./coverage/ ./lib/ && find ./src -name '*.js' -type f -delete",
    "deduplicate": "pnpm dedupe",
    "format": "npm-run-all format:*",
    "format:prettier": "prettier --write .",
    "format:sort-package-json": "sort-package-json",
    "lint": "npm-run-all --continue-on-error lint:*",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check .",
    "lint:sort-package-json": "sort-package-json --check",
    "prepare": "npm run build",
    "test": "npm-run-all --continue-on-error test:*",
    "test:jest": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --coverage"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@slack/bolt": "^5.0.0",
    "@slack/types": "^3.0.0",
    "@slack/web-api": "^8.0.0",
    "sprintf-js": "^1.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/sprintf-js": "^1.1.4",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.6",
    "sort-package-json": "^4.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "packageManager": "pnpm@11.15.1"
}
